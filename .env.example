# Credenciales git para setup.sh / repo-add.sh (copiar a .env — gitignoreado):
#   cp .env.example .env && chmod 600 .env
# Formato shell: KEY=valor, sin espacios alrededor del '='.
# Solo se necesitan las variables de los proveedores declarados en repos.yaml;
# los repos `local` y las URLs ssh (git@...) no usan token.

# ---------- GitHub (repos con provider: github) ----------
# PAT clasico o fine-grained con permiso de lectura de contenidos.
# crear en: github.com > Settings > Developer settings > Personal access tokens
#GITHUB_TOKEN=pega_aqui_tu_token
# usuario opcional (default: x-access-token, valido para PATs)
#GITHUB_USER=

# ---------- GitLab (repos con provider: gitlab) ----------
# PAT con scope read_repository (gitlab.com o instancia propia).
#GITLAB_TOKEN=pega_aqui_tu_token
# usuario opcional (default: oauth2, valido para PATs)
#GITLAB_USER=

# ---------- Bitbucket (repos con provider: bitbucket) ----------
# BITBUCKET_USER depende del TIPO de token que uses:
#   - App Password            -> tu usuario Bitbucket        (ej: mi-usuario)
#     crear en: bitbucket.org > Personal settings > App passwords
#     permiso minimo: Repositories: Read (Write si haras push)
#   - API token de Atlassian  -> tu email de la cuenta
#     crear en: id.atlassian.com > Security > API tokens
#   - Access Token de repo/proyecto/workspace -> x-token-auth
#     crear en: Repository/Workspace settings > Access tokens
# NOTA - API tokens CON scopes (ATATT de ~190+ caracteres): la API REST los
# acepta con tu email, pero GIT exige el usuario x-bitbucket-api-token-auth.
# setup.sh lo aplica solo; para forzarlo manualmente descomenta:
#BITBUCKET_GIT_USER=x-bitbucket-api-token-auth
#BITBUCKET_USER=
#BITBUCKET_TOKEN=pega_aqui_tu_token
